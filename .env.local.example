# Demo V3 · 本地环境变量模板
# 用法：cp .env.local.example .env.local 然后填真实值，重启 server 即可生效。
# .env.local 已在 .gitignore，不会提交。
# 读取机制：apps/server/src/server.js 顶部 require('dotenv').config({path:'.env.local'})。
# dotenv 没装或文件不存在都能降级到纯 process.env，不会 process.exit(1)。
# 规范见 demo/CODING-STANDARDS-v3.md §5.7 / §10.2。

# ---- LLM Provider ----
# 目前只从下面两个里选一个，不要同时配两个（wrapper 会以第一个非空的为准）。

# OpenAI 场景
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# 本机 Ollama 场景（OpenAI-compatible endpoint）
# OPENAI_API_KEY=ollama
# LLM_PROVIDER=openai
# LLM_MODEL=gemma4-aggressive:latest
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# Anthropic 场景（二选一）
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-3-5-haiku-latest

# ---- LLM 预算 / 超时 ----
# 以下默认值和 apps/server/src/v3Config.js 保持一致，只有要临时调才在这里覆盖。
LLM_TIMEOUT_MS=5000
LLM_MAX_IN_TOKENS=2000
LLM_MAX_OUT_TOKENS=200
LLM_PER_SECOND_CAP=5

# ---- 管理员命令（延续 docs/12 · P0-2 · 不允许默认密码）----
# 空值 = 禁用管理员命令（推荐 demo 场景）。
# 不要写 "DEFAULT" / "changeme" / "123456" / "admin"。
ADMIN_PASS=

# ---- 开发模式开关 ----
# 设为 1 时：
#   - 审计日志 data/audit/*.jsonl 写完整 prompt（默认只写 hash + 预览）
#   - 控制台打印 fallback 触发原因
V3_FULL_AUDIT=0

# V5 当前是画板优先。V3 NPC/记忆/聊天 AI 默认关闭；要回看 Week 1 demo 再打开。
V3_NPC_ENABLED=0
